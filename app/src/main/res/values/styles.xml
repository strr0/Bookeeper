<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="DiaryKey" parent="Widget.MaterialComponents.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/diary_key_radius</item>
        <item name="android:minHeight">@dimen/diary_key_height</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="DiaryKey.Digit" parent="DiaryKey">
        <item name="backgroundTint">@color/diary_key_digit_bg</item>
        <item name="android:textColor">@color/common_text_primary</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/diary_key_stroke</item>
    </style>

    <style name="DiaryKey.Zodiac" parent="DiaryKey">
        <item name="backgroundTint">@color/diary_key_zodiac_bg</item>
        <item name="android:textColor">@color/diary_key_zodiac_text</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/diary_key_zodiac_stroke</item>
    </style>

    <style name="DiaryKey.Operator" parent="DiaryKey">
        <item name="backgroundTint">@color/diary_key_operator_bg</item>
        <item name="android:textColor">@color/purple_500</item>
        <item name="android:textSize">20sp</item>
    </style>

    <style name="DiaryKey.Confirm" parent="DiaryKey">
        <item name="backgroundTint">@color/purple_500</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">28sp</item>
    </style>

    <style name="DiaryKey.Action" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/diary_key_radius</item>
        <item name="android:minHeight">@dimen/diary_key_height</item>
        <item name="strokeColor">@color/purple_500</item>
        <item name="android:textColor">@color/purple_500</item>
    </style>

    <style name="DiaryKey.Action.Delete" parent="DiaryKey.Action">
        <item name="strokeColor">@color/diary_key_delete_stroke</item>
        <item name="android:textColor">@color/diary_key_delete_text</item>
    </style>

</resources>
